{
  "components": {
    "schemas": {
      "BatchExtractBody": {
        "additionalProperties": false,
        "description": "Body for the batch-extract endpoint.\n\n`document_ids` is bounded so a misconfigured client can't enqueue\nthousands of documents in a single request \u2014 the cap is also enforced\nin the route handler so the error message can name the actual limit.",
        "properties": {
          "definition_id": {
            "minLength": 1,
            "title": "Definition Id",
            "type": "string"
          },
          "document_ids": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "title": "Document Ids",
            "type": "array"
          }
        },
        "required": [
          "document_ids",
          "definition_id"
        ],
        "title": "BatchExtractBody",
        "type": "object"
      },
      "Body_upload_document_api_documents_post": {
        "properties": {
          "file": {
            "contentMediaType": "application/octet-stream",
            "title": "File",
            "type": "string"
          }
        },
        "required": [
          "file"
        ],
        "title": "Body_upload_document_api_documents_post",
        "type": "object"
      },
      "DefinitionBody": {
        "additionalProperties": true,
        "properties": {
          "document": {
            "$ref": "#/components/schemas/DocumentSpec"
          }
        },
        "required": [
          "document"
        ],
        "title": "DefinitionBody",
        "type": "object"
      },
      "DocumentSpec": {
        "additionalProperties": true,
        "properties": {
          "document_description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Document Description"
          },
          "document_type": {
            "minLength": 1,
            "title": "Document Type",
            "type": "string"
          },
          "fields": {
            "items": {
              "$ref": "#/components/schemas/FieldSpec"
            },
            "title": "Fields",
            "type": "array"
          }
        },
        "required": [
          "document_type"
        ],
        "title": "DocumentSpec",
        "type": "object"
      },
      "ExtractRequest": {
        "properties": {
          "definition_id": {
            "minLength": 1,
            "title": "Definition Id",
            "type": "string"
          }
        },
        "required": [
          "definition_id"
        ],
        "title": "ExtractRequest",
        "type": "object"
      },
      "FieldExampleBody": {
        "additionalProperties": false,
        "description": "Body for the click-to-teach endpoint.\n\nCarries just the example value to append. The field is identified in the\nURL path so a single endpoint can handle both top-level fields and dotted\npaths like `line_items.amount` without overloading the body.",
        "properties": {
          "value": {
            "minLength": 1,
            "title": "Value",
            "type": "string"
          }
        },
        "required": [
          "value"
        ],
        "title": "FieldExampleBody",
        "type": "object"
      },
      "FieldSpec": {
        "additionalProperties": true,
        "description": "Validation for a single field inside a definition's `document.fields`.\n\nExtra keys are permitted at every layer so future schema additions don't\nrequire a server update. `fields` is recursive to support `type: array`.",
        "properties": {
          "affix": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Affix"
          },
          "available_options": {
            "anyOf": [
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Available Options"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "examples": {
            "anyOf": [
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Examples"
          },
          "extraction_instructions": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extraction Instructions"
          },
          "fields": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/FieldSpec"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fields"
          },
          "header_pattern": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Header Pattern"
          },
          "min_confidence": {
            "anyOf": [
              {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Confidence"
          },
          "multi_page": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Multi Page"
          },
          "name": {
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "normalizer": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Normalizer"
          },
          "pattern": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pattern"
          },
          "required_if": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Required If"
          },
          "type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type"
          },
          "use_llm_fallback": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Use Llm Fallback"
          },
          "visible_if": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Visible If"
          }
        },
        "required": [
          "name"
        ],
        "title": "FieldSpec",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
