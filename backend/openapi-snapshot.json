  "info": {
    "title": "Document Viewer API",
    "version": "snapshot"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/definitions": {
      "get": {
        "description": "List document class definitions, paginated.\n\nSame envelope as /api/documents. Sorted by id for stable pagination.",
        "operationId": "list_definitions_api_definitions_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Definitions"
      },
      "post": {
        "description": "Upload a new document class definition.\n\nValidated by Pydantic before this runs: missing/empty `document.document_type`\nor malformed `document.fields` returns 422 instead of crashing the matcher\nat extract time.\n\nIf a definition with the same slugged id already exists, returns 409\nConflict so a duplicate POST on retry doesn't silently overwrite the\nprevious version. Pass `?overwrite=true` (or use PATCH) to replace.\n\nWrite serialized on `_definitions_lock` so two concurrent POSTs can't\nrace each other into a half-written file.",
        "operationId": "create_definition_api_definitions_post",
        "parameters": [
          {
            "description": "Allow replacing an existing definition with the same id.",
            "in": "query",
            "name": "overwrite",
            "required": false,
            "schema": {
              "default": false,
              "description": "Allow replacing an existing definition with the same id.",
              "title": "Overwrite",
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DefinitionBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Definition"
      }
    },
    "/api/definitions/{def_id}": {
      "delete": {
        "description": "Remove a document class definition by id.\n\nReturns 404 if no definition with that id exists. The write side of the\ndefinitions store (create/patch/delete) is serialized on `_definitions_lock`\nso two concurrent mutations on the same id can't interleave into a\nhalf-written file or torn cache.",
        "operationId": "delete_definition_api_definitions__def_id__delete",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Delete Definition"
      },
      "get": {
        "description": "Get a specific document class definition.",
        "operationId": "get_definition_api_definitions__def_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Definition"
      },
      "patch": {
        "description": "Replace an existing definition in place.\n\nPydantic validates the body the same way `create_definition` does;\nsemantically this is \"upsert with id from the URL\". Returns 404 if the\ntarget doesn't exist (use POST to create), avoiding the foot-gun where a\ntypo in the URL silently creates a new definition under the wrong id.",
        "operationId": "patch_definition_api_definitions__def_id__patch",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DefinitionBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Patch Definition"
      }
    },
    "/api/definitions/{def_id}/codegen": {
      "get": {
        "description": "Render the definition as a downstream artifact.\n\nHands the same schema the matcher uses to a downstream consumer \u2014 a\nJSON Schema validator, a data-warehouse DDL, or a typed TypeScript\nclient \u2014 without anyone having to keep a hand-written copy in sync.\nField types are inferred from `normalizer` / `available_options`;\narray fields become a child table (SQL) / nested object array\n(JSON Schema, TS).",
        "operationId": "definition_codegen_api_definitions__def_id__codegen_get",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          },
          {
            "description": "Output format. One of: json-schema, sql-postgres, sql-bigquery, typescript.",
            "in": "query",
            "name": "format",
            "required": true,
            "schema": {
              "description": "Output format. One of: json-schema, sql-postgres, sql-bigquery, typescript.",
              "title": "Format",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Definition Codegen"
      }
    },
    "/api/definitions/{def_id}/fields/{field_name}/examples": {
      "post": {
        "description": "Append a value to a field's `examples` list (click-to-teach).\n\nSupports a dotted path for one level of array sub-fields, e.g.\n``line_items.amount`` resolves to the ``amount`` sub-field of the\n``line_items`` array. Refuses duplicates with 409 so a repeated click\ndoesn't silently no-op (the caller can swallow the 409 if it prefers\nidempotent behavior).\n\nWrite-side is serialized on `_definitions_lock` and persisted via\n`_atomic_write_json`, matching every other definition mutation.",
        "operationId": "add_field_example_api_definitions__def_id__fields__field_name__examples_post",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "field_name",
            "required": true,
            "schema": {
              "title": "Field Name",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FieldExampleBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Add Field Example"
      }
    },
    "/api/definitions/{def_id}/versions": {
      "get": {
        "description": "List the revision archive for a definition (newest first).\nReturns metadata only; the content is fetched per-version.\n\n404 if neither the live definition nor any archived version exists\nfor this id \u2014 that combination only happens for a typo / never-used\nid, and the inconsistent 200 with empty items obscured the bug.\nA definition that has been deleted but had history still returns\n200 with the archived items so users can browse / resurrect it.",
        "operationId": "list_definition_versions_api_definitions__def_id__versions_get",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Definition Versions"
      }
    },
    "/api/definitions/{def_id}/versions/{version_id}": {
      "get": {
        "description": "Fetch one archived version's full content.",
        "operationId": "get_definition_version_api_definitions__def_id__versions__version_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "def_id",
            "required": true,
            "schema": {
              "title": "Def Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "version_id",
            "required": true,
            "schema": {
              "title": "Version Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Definition Version"
      }
    },
    "/api/documents": {
      "get": {
        "description": "List documents in the test docs dir, paginated.\n\nThe response is a `{items, total, limit, offset}` envelope rather than a\nbare array; old callers can still read `items` to get the same shape.\nCached by directory signature so back-to-back GETs (e.g. polling) don't\nre-stat every file in the dir.",
        "operationId": "list_documents_api_documents_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Documents"
      },
      "post": {
        "description": "Accept a PDF/DOCX/PPTX upload and persist it under TEST_DOCS_DIR.\n\nValidates extension up-front; size is bounded by the body-size middleware\nusing a separate, larger cap for this path. A filename collision gets a\n`-1`, `-2`, \u2026 suffix rather than overwriting an existing document, so an\naccidental re-upload doesn't destroy an in-flight investigation.",
        "operationId": "upload_document_api_documents_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_document_api_documents_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Upload Document"
      }
    },
    "/api/documents/{doc_id}": {
      "delete": {
        "description": "Remove a document from disk + flush every cache that referenced it.\n\nReturns 404 if no document with that id exists, mirroring the rest of\nthe API. Render / text caches are pruned so a re-upload under the same\nfilename (which would yield the same doc_id) won't serve stale\nrasterized pages from before the deletion.",
        "operationId": "delete_document_api_documents__doc_id__delete",
        "parameters": [
          {
            "in": "path",
            "name": "doc_id",
            "required": true,
            "schema": {
              "title": "Doc Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Delete Document"
      },
      "get": {
        "description": "Get document metadata. Fast \u2014 does not run text extraction or page rasterization.\n\nKicks off a background prefetch for page 1 + text extraction so by the\ntime the frontend renders the viewer and POSTs to /extract, both are\ntypically already in the cache.",
        "operationId": "get_document_api_documents__doc_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "doc_id",
            "required": true,
            "schema": {
              "title": "Doc Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Document"
      }
    },
    "/api/documents/{doc_id}/export": {
      "get": {
        "description": "Run extraction + apply target_tables transforms, return flat rows.\n\nWraps `/extract` and the transform engine. JSON returns every target\ntable at once; CSV requires `?table=<name>` because a single CSV can't\nrepresent multiple tables coherently. Uses the same semaphore as\n`/extract` so this endpoint can't be used to bypass the concurrency cap.",
        "operationId": "export_document_api_documents__doc_id__export_get",
        "parameters": [
          {
            "in": "path",
            "name": "doc_id",
            "required": true,
