    "/api/documents/{doc_id}/extract": {
      "post": {
        "description": "Extract fields from a document using a definition.\n\nSync `def` (not async) so FastAPI dispatches this to the threadpool;\nDocling's `convert` blocks the calling thread, and using `async def` here\nwould freeze the event loop for the duration of every other request.\n\nTracked via `_track_inflight` so a SIGTERM during a long extraction\nwaits for completion (bounded by SCHEMABUILDER_SHUTDOWN_GRACE) instead\nof killing the Docling pipeline mid-run.\n\nCached on (doc_signature, matching-relevant definition fields). The\ncache survives restarts via SQLite. Pass ?refresh=true to bypass.",
        "operationId": "extract_fields_api_documents__doc_id__extract_post",
        "parameters": [
          {
            "in": "path",
            "name": "doc_id",
            "required": true,
            "schema": {
              "title": "Doc Id",
              "type": "string"
            }
          },
          {
            "description": "Bypass the extraction cache.",
            "in": "query",
            "name": "refresh",
            "required": false,
            "schema": {
              "default": false,
              "description": "Bypass the extraction cache.",
              "title": "Refresh",
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Extract Fields"
      }
    },
    "/api/documents/{doc_id}/pages/{page_no}": {
      "get": {
        "description": "Get a rendered page image as PNG. Pages are rendered on demand and memoized.\n\n`page_no` is constrained to a sane range so junk like negative numbers or\n`page_no=999999` is rejected at the route boundary (422) instead of\npropagating through render and returning a confused 404. The upper bound\nis intentionally generous; any real PDF that exceeds it would already be\na server-side performance problem.\n\nSends an ETag tied to the file's mtime/size so the browser can revalidate\ncheaply once the max-age expires (or when the user reloads with a warm\ndisk cache); a matching If-None-Match short-circuits to 304 without\nre-sending the PNG bytes.",
        "operationId": "get_page_image_api_documents__doc_id__pages__page_no__get",
        "parameters": [
          {
            "in": "path",
            "name": "doc_id",
            "required": true,
            "schema": {
              "title": "Doc Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "page_no",
            "required": true,
            "schema": {
              "maximum": 10000,
              "minimum": 1,
              "title": "Page No",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Page Image"
      }
    },
